# Copia este archivo a .env y rellena los valores
# cp .env.example .env

# — API URL —
# Elige UNO de los tres entornos (descomenta el que quieras usar):

# Producción (Railway)
#EXPO_PUBLIC_API_URL=https://roomies-production-c884.up.railway.app/api

# Desarrollo en Railway (rama dev)
#EXPO_PUBLIC_API_URL=https://roomies-dev.up.railway.app/api

# Desarrollo local (Docker Compose en la misma máquina/red)
#EXPO_PUBLIC_API_URL=http://192.168.1.X:3001/api
# Android emulator:
#EXPO_PUBLIC_API_URL=http://10.0.2.2:3001/api
# Web/local en la misma maquina:
#EXPO_PUBLIC_API_URL=http://localhost:3001/api

EXPO_PUBLIC_API_URL=https://roomies-dev.up.railway.app/api

# — Mapbox —
# Obtén tu token en https://account.mapbox.com (necesario para autocompletado de dirección)
EXPO_PUBLIC_MAPBOX_TOKEN=pk.ey...

# — Google OAuth —
# Obtén los Client IDs en https://console.cloud.google.com → Credenciales → OAuth 2.0
# Web Client ID (usado por Expo Go y el backend para verificar idTokens)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
# Android Client ID (package: host.exp.exponent, SHA-1 del debug keystore de Expo)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
# iOS Client ID (bundle ID de la app nativa; dejar vacío si solo usas Expo Go)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
