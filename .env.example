# Copia este archivo a .env y rellena los valores reales
# cp .env.example .env

# PostgreSQL (usado por Docker Compose y el backend)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=roomies

# JWT — usa una cadena larga y aleatoria en producción
JWT_SECRET=cambia_este_secreto

# IP de tu máquina en la red Wi-Fi local (ipconfig → IPv4 del adaptador Wi-Fi)
HOST_IP=192.168.1.X
