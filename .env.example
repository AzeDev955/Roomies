# Copia este archivo a .env y rellena los valores reales
# cp .env.example .env

# PostgreSQL (usado por Docker Compose y el backend)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_esta_password
POSTGRES_DB=roomies

# JWT — usa una cadena larga y aleatoria en producción
JWT_SECRET=cambia_este_secreto

# IP de tu máquina en la red Wi-Fi local (ipconfig → IPv4 del adaptador Wi-Fi)
HOST_IP=192.168.1.X

# Mapbox Geocoding — obtén tu token en https://account.mapbox.com
EXPO_PUBLIC_MAPBOX_TOKEN=pk.ey...

# Google OAuth — Web Client ID (Google Cloud Console → Credenciales → OAuth 2.0)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com

# Expo Access Token — expo.dev → avatar → Access Tokens → Create Token
# Necesario para que Docker autentique el CLI de Expo como tu cuenta (@usuario)
# y el proxy auth.expo.io pueda redirigir el callback de Google a la app
EXPO_TOKEN=tu_expo_access_token_aqui
