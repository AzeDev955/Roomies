generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RolUsuario {
  CASERO
  INQUILINO
}

enum EstadoIncidencia {
  PENDIENTE
  EN_PROCESO
  RESUELTA
}

enum PrioridadIncidencia {
  VERDE
  AMARILLO
  ROJO
}

enum TipoHabitacion {
  DORMITORIO
  BANO
  COCINA
  SALON
  OTRO
}

enum EstadoPresencia {
  ACTIVO
  AUSENTE_VACACIONES
}

enum EstadoTurno {
  PENDIENTE
  HECHO
  NO_HECHO
}

enum EstadoDeuda {
  PENDIENTE
  PAGADA
}

enum EstadoItem {
  NUEVO
  BUENO
  DESGASTADO
  ROTO
}

model Usuario {
  id                 Int                      @id @default(autoincrement())
  nombre             String
  apellidos          String?
  documento_identidad String?                  @unique
  email              String                   @unique
  password_hash      String?
  google_id          String?                  @unique
  telefono           String?
  rol                RolUsuario
  correo_verificado  Boolean                  @default(false)
  token_verificacion String?
  expo_push_token    String?
  balance_limpieza   Float                    @default(0)
  estado_presencia   EstadoPresencia          @default(ACTIVO)
  viviendas          Vivienda[]
  habitaciones       Habitacion[]
  incidencias        Incidencia[]
  anuncios           Anuncio[]
  turnos_limpieza    TurnoLimpieza[]
  asignaciones_fijas AsignacionLimpiezaFija[]
  gastos_pagados     Gasto[]
  deudas_a_pagar     Deuda[]                  @relation("DeudorDeuda")
  deudas_a_cobrar    Deuda[]                  @relation("AcreedorDeuda")
}

model Vivienda {
  id               Int              @id @default(autoincrement())
  casero_id        Int
  casero           Usuario          @relation(fields: [casero_id], references: [id])
  alias_nombre     String
  direccion        String
  codigo_postal    String
  ciudad           String
  provincia        String
  habitaciones     Habitacion[]
  incidencias      Incidencia[]
  anuncios         Anuncio[]
  zonas_limpieza   ZonaLimpieza[]
  gastos           Gasto[]
  items_inventario ItemInventario[]
}

model Habitacion {
  id                Int              @id @default(autoincrement())
  vivienda_id       Int
  vivienda          Vivienda         @relation(fields: [vivienda_id], references: [id])
  inquilino_id      Int?
  inquilino         Usuario?         @relation(fields: [inquilino_id], references: [id])
  nombre            String
  tipo              TipoHabitacion   @default(DORMITORIO)
  es_habitable      Boolean          @default(true)
  metros_cuadrados  Float?
  codigo_invitacion String?          @unique
  incidencias       Incidencia[]
  items_inventario  ItemInventario[]
}

model Incidencia {
  id             Int                 @id @default(autoincrement())
  vivienda_id    Int
  vivienda       Vivienda            @relation(fields: [vivienda_id], references: [id])
  creador_id     Int
  creador        Usuario             @relation(fields: [creador_id], references: [id])
  habitacion_id  Int?
  habitacion     Habitacion?         @relation(fields: [habitacion_id], references: [id])
  titulo         String
  descripcion    String
  estado         EstadoIncidencia    @default(PENDIENTE)
  prioridad      PrioridadIncidencia @default(VERDE)
  fecha_creacion DateTime            @default(now())
}

model Anuncio {
  id             Int      @id @default(autoincrement())
  vivienda_id    Int
  vivienda       Vivienda @relation(fields: [vivienda_id], references: [id])
  autor_id       Int
  autor          Usuario  @relation(fields: [autor_id], references: [id])
  titulo         String
  contenido      String
  fecha_creacion DateTime @default(now())
}

// ── Módulo de gastos y balances ───────────────────────────────────────────────

model Gasto {
  id             Int      @id @default(autoincrement())
  concepto       String
  importe        Float
  fecha_creacion DateTime @default(now())
  pagador_id     Int
  pagador        Usuario  @relation(fields: [pagador_id], references: [id])
  vivienda_id    Int
  vivienda       Vivienda @relation(fields: [vivienda_id], references: [id])
  deudas         Deuda[]
}

model Deuda {
  id          Int         @id @default(autoincrement())
  gasto_id    Int
  gasto       Gasto       @relation(fields: [gasto_id], references: [id])
  deudor_id   Int
  deudor      Usuario     @relation("DeudorDeuda", fields: [deudor_id], references: [id])
  acreedor_id Int
  acreedor    Usuario     @relation("AcreedorDeuda", fields: [acreedor_id], references: [id])
  importe     Float
  estado      EstadoDeuda @default(PENDIENTE)
}

model ItemInventario {
  id             Int         @id @default(autoincrement())
  nombre         String
  descripcion    String?
  estado         EstadoItem  @default(BUENO)
  revisado_por_inquilino Boolean @default(false)
  habitacion_id  Int?
  habitacion     Habitacion? @relation(fields: [habitacion_id], references: [id])
  vivienda_id    Int?
  vivienda       Vivienda?   @relation(fields: [vivienda_id], references: [id])
  fecha_registro DateTime    @default(now())
  fotos          FotoAsset[]
}

model FotoAsset {
  id           Int            @id @default(autoincrement())
  url          String
  item_id      Int
  item         ItemInventario @relation(fields: [item_id], references: [id])
  fecha_subida DateTime       @default(now())
}

// ── Módulo de limpieza ────────────────────────────────────────────────────────

model ZonaLimpieza {
  id                 Int                      @id @default(autoincrement())
  vivienda_id        Int
  vivienda           Vivienda                 @relation(fields: [vivienda_id], references: [id])
  nombre             String
  peso               Float
  activa             Boolean                  @default(true)
  turnos             TurnoLimpieza[]
  asignaciones_fijas AsignacionLimpiezaFija[]
}

/// Tabla de asignaciones fijas: una zona siempre la limpia el mismo usuario,
/// sin participar en la rotación global. Su peso SÍ cuenta para el balance.
model AsignacionLimpiezaFija {
  id         Int          @id @default(autoincrement())
  zona_id    Int
  zona       ZonaLimpieza @relation(fields: [zona_id], references: [id])
  usuario_id Int
  usuario    Usuario      @relation(fields: [usuario_id], references: [id])

  @@unique([zona_id, usuario_id])
}

/// Registro semanal del reparto. Generado por el algoritmo al inicio de cada semana.
model TurnoLimpieza {
  id           Int          @id @default(autoincrement())
  usuario_id   Int
  usuario      Usuario      @relation(fields: [usuario_id], references: [id])
  zona_id      Int
  zona         ZonaLimpieza @relation(fields: [zona_id], references: [id])
  fecha_inicio DateTime
  fecha_fin    DateTime
  estado       EstadoTurno  @default(PENDIENTE)
}
